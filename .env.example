# Google Gemini API key — required by the conversational agent (/agent/chat).
# Get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_key_here

# Where the agent's prediction tool points. Kept for completeness; by default the
# agent runs inference in-process and does not perform an HTTP self-call.
PREDICT_API_URL=http://localhost:8000/predict
